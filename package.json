{
  "name": "electrobun-vite-workspace",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*",
    "templates/*"
  ],
  "scripts": {
    "dev": "bun run dev:demo",
    "dev:all": "bun run scripts/dev.ts",
    "dev:app": "bun run --cwd apps/demo dev",
    "dev:demo": "bun run --cwd apps/demo dev",
    "dev:template": "bun run --cwd templates/react-ts dev",
    "dev:docs": "bun run --cwd apps/docs dev",
    "info": "bun packages/electrobun-vite/dist/bin/electrobun-vite.js info",
    "new": "bun packages/electrobun-vite/dist/bin/create-electrobun.js",
    "build": "bun run build:package && bun run build:demo && bun run build:template",
    "build:all": "bun run build && bun run build:docs",
    "build:package": "bun run --cwd packages/electrobun-vite build",
    "build:demo": "bun run --cwd apps/demo build",
    "build:template": "bun run --cwd templates/react-ts build",
    "build:docs": "bun run --cwd apps/docs build",
    "typecheck": "bun run typecheck:package && bun run typecheck:demo && bun run typecheck:template",
    "typecheck:all": "bun run typecheck && bun run typecheck:docs",
    "typecheck:package": "bun run --cwd packages/electrobun-vite typecheck",
    "typecheck:demo": "bun run --cwd apps/demo typecheck",
    "typecheck:template": "bun run --cwd templates/react-ts typecheck",
    "typecheck:docs": "bun run --cwd apps/docs typecheck",
    "postinstall": "bun run build:package"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  }
}
