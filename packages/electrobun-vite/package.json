{
  "name": "@nova-infra/electrobun-vite",
  "version": "0.1.8",
  "homepage": "https://nova-infra.github.io/electrobun-vite/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nova-infra/electrobun-vite.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "electrobun-vite": "./dist/bin/electrobun-vite.js",
    "create-electrobun": "./dist/bin/create-electrobun.js"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./metadata": {
      "types": "./dist/metadata.d.ts",
      "import": "./dist/metadata.js"
    }
  },
  "files": [
    "assets/logo.png",
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json && chmod +x ./dist/bin/electrobun-vite.js ./dist/bin/create-electrobun.js && ln -sf electrobun-vite.js ./dist/bin/electrobun-vite && ln -sf create-electrobun.js ./dist/bin/create-electrobun",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cac": "^6.7.14",
    "picocolors": "^1.1.1",
    "vite": "8.0.0",
    "@nova-infra/template-react-ts": "latest"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  }
}
