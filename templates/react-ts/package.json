{
  "name": "@electrobun-vite/template-react-ts",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "dev:web": "vite --host 127.0.0.1 --port 5173",
    "dev:desktop": "electrobun dev --watch",
    "build:web": "vite build",
    "build:desktop": "electrobun build",
    "build": "bun run build:web && bun run build:desktop",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "electrobun": "1.16.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "typescript": "^5.9.3",
    "vite": "8.0.0"
  }
}
